  "test_suites": [
    {
      "suite_name": "basic_reference_selection",
      "description": "Tests for basic single-reference queries",
      "priority": "critical",
      "tests": [
        {
          "test_id": "ref_001",
          "name": "Simple coin price query",
          "category": "reference_selection",
          "priority": "critical",
          "user_query": "What's the current price of Bitcoin?",
          "expected_references": [
            "core.md",
            "coins.md"
          ],
          "required_references": [
            "core.md",
            "coins.md"
          ],
          "forbidden_references": [
            "onchain-pools.md",
            "derivatives.md",
            "treasury.md"
          ],
          "expected_api_type": "coingecko",
          "reasoning": "Core is always loaded. Coin price queries require coins.md for /simple/price or /coins/markets endpoints.",
          "tags": [
            "price",
            "basic",
            "coingecko"
          ],
          "complexity": "simple"
        },
        {
          "test_id": "ref_002",
          "name": "Historical OHLC data query",
          "category": "reference_selection",
          "priority": "critical",
          "user_query": "Show me Bitcoin's OHLC data for the last 30 days",
          "expected_references": [
            "core.md",
            "coin-history.md"
          ],
          "required_references": [
            "core.md",
            "coin-history.md"
          ],
          "forbidden_references": [
            "coin-supply.md",
            "nfts.md",
            "onchain-ohlcv-trades.md"
          ],
          "expected_api_type": "coingecko",
          "reasoning": "Historical OHLC data is covered in coin-history.md, not coins.md. The onchain-ohlcv-trades.md is for DEX-specific data.",
          "tags": [
            "historical",
            "ohlc",
            "charts",
            "coingecko"
          ],
          "complexity": "simple"
        },
