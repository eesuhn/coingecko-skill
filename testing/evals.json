        {
          "test_id": "multi_003",
          "name": "Cross-API comparison",
          "category": "multi_reference",
          "priority": "high",
          "user_query": "Compare the aggregated price from CoinGecko with the Uniswap pool price for USDC",
          "expected_references": [
            "core.md",
            "coins.md",
            "onchain-pools.md"
          ],
          "required_references": [
            "core.md"
          ],
          "forbidden_references": [],
          "expected_api_type": "both",
          "reasoning": "Needs both CoinGecko (coins.md for aggregated price) and GeckoTerminal (onchain-pools.md for DEX pool price).",
          "tags": [
            "cross-api",
            "price",
            "comparison",
            "multi-domain"
          ],
          "complexity": "complex"
        }
