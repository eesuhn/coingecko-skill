    {
      "suite_name": "api_routing",
      "description": "Tests for CoinGecko vs GeckoTerminal routing logic",
      "priority": "critical",
      "tests": [
        {
          "test_id": "route_001",
          "name": "DEX pool data query",
          "category": "api_routing",
          "priority": "critical",
          "user_query": "Show me trending pools on Uniswap",
          "expected_references": [
            "core.md",
            "onchain-pools.md"
          ],
          "required_references": [
            "core.md",
            "onchain-pools.md"
          ],
          "forbidden_references": [
            "coins.md",
            "exchanges.md"
          ],
          "expected_api_type": "geckoterminal",
          "reasoning": "Pool data is GeckoTerminal-specific. onchain-networks.md may be optionally needed for DEX ID resolution.",
          "tags": [
            "pools",
            "dex",
            "onchain",
            "geckoterminal"
          ],
          "complexity": "moderate"
        },
        {
          "test_id": "route_002",
          "name": "Onchain token with holders",
          "category": "api_routing",
          "priority": "high",
          "user_query": "Get on-chain data for token 0x1234abcd on Ethereum including holder information",
          "expected_references": [
            "core.md",
            "onchain-tokens.md"
          ],
          "required_references": [
            "core.md",
            "onchain-tokens.md"
          ],
          "forbidden_references": [
            "contract.md",
            "coins.md"
          ],
          "expected_api_type": "geckoterminal",
          "reasoning": "Holder information is only available in GeckoTerminal's onchain-tokens.md. CoinGecko's contract.md doesn't have holder data.",
          "tags": [
            "onchain",
            "token",
            "holders",
            "geckoterminal"
          ],
          "complexity": "moderate"
        },
        {
          "test_id": "route_003",
          "name": "CEX exchange volume (Binance)",
          "category": "api_routing",
          "priority": "critical",
          "user_query": "What's the trading volume on Binance for ETH/USDT?",
          "expected_references": [
            "core.md",
            "exchanges.md"
          ],
          "required_references": [
            "core.md",
            "exchanges.md"
          ],
          "forbidden_references": [
            "onchain-pools.md",
            "onchain-ohlcv-trades.md"
          ],
          "expected_api_type": "coingecko",
          "reasoning": "Binance is a CEX (centralized exchange), so should use CoinGecko's exchanges.md, not GeckoTerminal.",
          "tags": [
            "exchange",
            "cex",
            "volume",
            "coingecko"
          ],
          "complexity": "moderate"
        }
      ]
